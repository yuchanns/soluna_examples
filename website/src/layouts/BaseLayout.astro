---
import '../styles/theme.css'

interface Props {
  title: string
  description?: string
  mainClass?: string
}

const { title, description = '', mainClass = '' } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="page-shell">
      <main class:list={['page-main', mainClass]}>
        <slot />
      </main>
      <footer class="site-footer">
        <a
          class="source-link"
          href="https://github.com/yuchanns/soluna_examples"
          rel="noreferrer"
          aria-label="Source repository on GitHub"
        >
          <svg class="github-mark" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M12 0C5.37 0 0 5.5 0 12.29c0 5.43 3.44 10.03 8.2 11.66.6.11.82-.27.82-.59 0-.29-.01-1.06-.02-2.09-3.34.74-4.04-1.65-4.04-1.65-.55-1.42-1.34-1.8-1.34-1.8-1.09-.77.08-.75.08-.75 1.2.09 1.84 1.27 1.84 1.27 1.08 1.89 2.82 1.35 3.5 1.03.11-.8.42-1.35.76-1.66-2.66-.31-5.46-1.36-5.46-6.07 0-1.34.47-2.43 1.24-3.29-.13-.31-.54-1.56.12-3.25 0 0 1.01-.33 3.3 1.26A11.16 11.16 0 0 1 12 5.94c1.02 0 2.04.14 3 .42 2.29-1.59 3.3-1.26 3.3-1.26.66 1.69.25 2.94.12 3.25.77.86 1.24 1.95 1.24 3.29 0 4.72-2.8 5.76-5.47 6.06.43.38.81 1.13.81 2.28 0 1.65-.02 2.98-.02 3.38 0 .33.22.71.83.59A12.28 12.28 0 0 0 24 12.29C24 5.5 18.63 0 12 0Z"
            />
          </svg>
        </a>
      </footer>
    </div>
  </body>
</html>
